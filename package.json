{
	"name": "@feisscrew/ui",
	"version": "0.0.1",
	"description": "Internal React component library",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./index.css": "./dist/index.css"
	},
	"type": "module",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts --format esm,cjs --dts",
		"dev": "tsup src/index.ts --watch --format esm,cjs --dts"
	},
	"devDependencies": {
		"@types/react": "^18.0.0",
		"@types/react-dom": "^18.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.4.5"
	},
	"peerDependencies": {
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-icons": "^5.6.0"
	},
	"dependencies": {
		"@cloudinary/react": "^1.14.4",
		"@cloudinary/url-gen": "^1.22.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2"
	}
}
